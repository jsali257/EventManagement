# ============================================
# Community Outreach & Volunteer Management
# Environment Configuration
# ============================================
# Copy this file to .env.local and fill values

# --- Database ---
DATABASE_URL="postgresql://username:password@localhost:5432/volunteer_mgmt?schema=public"

# --- Auth.js ---
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# Production:
# AUTH_URL="https://your-domain.com"

# --- Application ---
NEXT_PUBLIC_APP_NAME="Community Outreach & Volunteer Management System"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEPARTMENT_NAME="Public Education Department"

# --- File Uploads ---
UPLOAD_PROVIDER="local"
# Options: "local" | "uploadthing"
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE_MB="25"
ALLOWED_FILE_TYPES="pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif,webp"

# UploadThing (if UPLOAD_PROVIDER=uploadthing)
# UPLOADTHING_SECRET="sk_live_..."
# UPLOADTHING_APP_ID="..."

# --- Email (Optional - future module) ---
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="notifications@example.com"
# SMTP_PASSWORD="..."
# SMTP_FROM="no-reply@example.com"

# --- Node ---
NODE_ENV="development"
