// ============================================================
// Prisma Schema
// Community Outreach & Volunteer Management System
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Auth.js Required Models
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// User & Role Management
// ============================================================

enum UserRole {
  ADMIN
  EMPLOYEE
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?
  passwordHash  String?   @map("password_hash")
  role          UserRole  @default(EMPLOYEE)
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  accounts      Account[]
  sessions      Session[]
  employee      Employee?
  activityLogs  ActivityLog[]
  notifications Notification[]
  assignedBy    EventAssignment[] @relation("AssignedBy")
  attendanceMarkedBy AttendanceRecord[] @relation("MarkedBy")
  uploadedAttachments Attachment[]
  uploadedPhotos     EventPhoto[]
  createdEvents      Event[]           @relation("CreatedBy")

  @@map("users")
}

// ============================================================
// Department
// ============================================================

model Department {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  color       String     @default("#3B82F6")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  employees Employee[]

  @@map("departments")
}

// ============================================================
// Employee
// ============================================================

enum EmployeeStatus {
  AVAILABLE
  BUSY
  VACATION
  SICK
  TRAINING
  INACTIVE
}

model Employee {
  id             String         @id @default(cuid())
  employeeId     String         @unique @map("employee_id")
  firstName      String         @map("first_name")
  lastName       String         @map("last_name")
  email          String         @unique
  phone          String?
  jobTitle       String         @map("job_title")
  departmentId   String         @map("department_id")
  status         EmployeeStatus @default(AVAILABLE)
  profilePicture String?        @map("profile_picture")
  avatarColor    String         @default("#3B82F6") @map("avatar_color")
  userId         String?        @unique @map("user_id")

  // Stats (denormalized for performance)
  volunteerHours  Float    @default(0) @map("volunteer_hours")
  eventsAttended  Int      @default(0) @map("events_attended")
  attendanceRate  Float    @default(0) @map("attendance_rate")
  volunteerScore  Int      @default(0) @map("volunteer_score")
  lastVolunteerDate DateTime? @map("last_volunteer_date")

  isActive  Boolean  @default(true) @map("is_active")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  department    Department           @relation(fields: [departmentId], references: [id])
  user          User?                @relation(fields: [userId], references: [id])
  assignments   EventAssignment[]
  attendance    AttendanceRecord[]
  availability  EmployeeAvailability[]
  organizedEvents Event[]            @relation("EventOrganizer")

  @@map("employees")
}

// ============================================================
// Employee Availability
// ============================================================

model EmployeeAvailability {
  id           String   @id @default(cuid())
  employeeId   String   @map("employee_id")
  date         DateTime @db.Date
  isUnavailable Boolean @default(true) @map("is_unavailable")
  reason       String?
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@map("employee_availability")
}

// ============================================================
// Event Category
// ============================================================

model EventCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String   @default("#3B82F6")
  icon        String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  events Event[]

  @@map("event_categories")
}

// ============================================================
// Event
// ============================================================

enum EventStatus {
  UPCOMING
  TODAY
  COMPLETED
  CANCELLED
  FULL
  NEEDS_VOLUNTEERS
  PARTIALLY_FILLED
}

model Event {
  id            String      @id @default(cuid())
  title         String
  description   String?
  categoryId    String      @map("category_id")
  date          DateTime    @db.Date
  startTime     String      @map("start_time")
  endTime       String      @map("end_time")
  location      String
  address       String?
  latitude      Float?
  longitude     Float?
  minVolunteers Int         @default(1) @map("max_volunteers")
  organizerId   String      @map("organizer_id")
  notes         String?
  coverImage    String?     @map("cover_image")
  status        EventStatus @default(UPCOMING)
  isCancelled   Boolean     @default(false) @map("is_cancelled")
  cancelledAt   DateTime?   @map("cancelled_at")
  cancelledReason String?   @map("cancelled_reason")
  createdById   String      @map("created_by_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // Relations
  category    EventCategory     @relation(fields: [categoryId], references: [id])
  organizer   Employee          @relation("EventOrganizer", fields: [organizerId], references: [id])
  createdBy   User              @relation("CreatedBy", fields: [createdById], references: [id])
  assignments EventAssignment[]
  attendance  AttendanceRecord[]
  attachments Attachment[]
  photos      EventPhoto[]
  activityLog ActivityLog[]

  @@map("events")
}

// ============================================================
// Event Assignments (Volunteers)
// ============================================================

model EventAssignment {
  id           String   @id @default(cuid())
  eventId      String   @map("event_id")
  employeeId   String   @map("employee_id")
  assignedById String   @map("assigned_by_id")
  assignedAt   DateTime @default(now()) @map("assigned_at")
  notes        String?
  isConfirmed  Boolean  @default(true) @map("is_confirmed")

  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id])
  assignedBy User     @relation("AssignedBy", fields: [assignedById], references: [id])

  @@unique([eventId, employeeId])
  @@map("event_assignments")
}

// ============================================================
// Attendance
// ============================================================

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  eventId    String           @map("event_id")
  employeeId String           @map("employee_id")
  status     AttendanceStatus
  markedById String           @map("marked_by_id")
  markedAt   DateTime         @default(now()) @map("marked_at")
  notes      String?

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])
  markedBy User     @relation("MarkedBy", fields: [markedById], references: [id])

  @@unique([eventId, employeeId])
  @@map("attendance_records")
}

// ============================================================
// Attachments
// ============================================================

enum FileType {
  PDF
  WORD
  EXCEL
  IMAGE
  OTHER
}

model Attachment {
  id           String   @id @default(cuid())
  eventId      String?  @map("event_id")
  fileName     String   @map("file_name")
  originalName String   @map("original_name")
  fileSize     Int      @map("file_size")
  fileType     FileType @map("file_type")
  mimeType     String   @map("mime_type")
  filePath     String   @map("file_path")
  uploadedById String   @map("uploaded_by_id")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  event      Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  uploadedBy User   @relation(fields: [uploadedById], references: [id])

  @@map("attachments")
}

// ============================================================
// Event Photos
// ============================================================

model EventPhoto {
  id           String   @id @default(cuid())
  eventId      String   @map("event_id")
  fileName     String   @map("file_name")
  originalName String   @map("original_name")
  fileSize     Int      @map("file_size")
  filePath     String   @map("file_path")
  caption      String?
  uploadedById String   @map("uploaded_by_id")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  event      Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation(fields: [uploadedById], references: [id])

  @@map("event_photos")
}

// ============================================================
// Activity Log (Audit Trail)
// ============================================================

enum ActivityAction {
  EVENT_CREATED
  EVENT_UPDATED
  EVENT_DELETED
  EVENT_CANCELLED
  VOLUNTEER_ASSIGNED
  VOLUNTEER_REMOVED
  ATTENDANCE_MARKED
  ATTENDANCE_UPDATED
  EMPLOYEE_CREATED
  EMPLOYEE_UPDATED
  EMPLOYEE_DELETED
  DEPARTMENT_CREATED
  DEPARTMENT_UPDATED
  CATEGORY_CREATED
  CATEGORY_UPDATED
  PHOTO_UPLOADED
  PHOTO_DELETED
  ATTACHMENT_UPLOADED
  ATTACHMENT_DELETED
  AVAILABILITY_SET
  AVAILABILITY_REMOVED
  SETTINGS_UPDATED
  USER_LOGIN
  USER_LOGOUT
  USER_CREATED
  USER_UPDATED
}

model ActivityLog {
  id          String         @id @default(cuid())
  action      ActivityAction
  entityType  String         @map("entity_type")
  entityId    String         @map("entity_id")
  description String
  metadata    Json?
  userId      String         @map("user_id")
  eventId     String?        @map("event_id")
  ipAddress   String?        @map("ip_address")
  userAgent   String?        @map("user_agent")
  createdAt   DateTime       @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id])
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ============================================================
// Notifications
// ============================================================

enum NotificationType {
  ASSIGNED
  REMOVED
  EVENT_UPDATED
  EVENT_CANCELLED
  VOLUNTEER_NEEDED
  ATTENDANCE_MISSING
  GENERAL
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  message     String
  userId      String           @map("user_id")
  entityType  String?          @map("entity_type")
  entityId    String?          @map("entity_id")
  actionUrl   String?          @map("action_url")
  isRead      Boolean          @default(false) @map("is_read")
  readAt      DateTime?        @map("read_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================================
// Application Settings
// ============================================================

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// ============================================================
// Email Templates
// ============================================================

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  subject   String
  bodyHtml  String   @db.Text @map("body_html")
  bodyText  String?  @db.Text @map("body_text")
  variables Json?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}
